// ESP32 device credentials.
// This file is gitignored — do NOT commit it.
// Edit WIFI_SSID and WIFI_PASS to connect via WiFi.
// Leave WIFI_SSID empty to use serial UART transport instead.

/// WiFi SSID. Set to "" to skip WiFi and use serial UART.
pub const WIFI_SSID: &str = "";

/// WiFi WPA2 password.
pub const WIFI_PASS: &str = "";

/// FIPS VPS IP address (dotted-quad). Replace with your VPS IP. DNS not yet supported.
pub const FIPS_HOST: &str = "0.0.0.0";

/// FIPS VPS UDP port.
pub const FIPS_PORT: u16 = 2121;

/// Device identity secret key: 31 zero bytes + 0x02 (secp256k1 generator * 2).
/// npub: npub1ccz8l9zpa47k6vz9gphftsrumpw80rjt3nhnefat4symjhrsnmjs38mnyd
/// node_addr: 0135da2f8acf7b9e3090939432e47684
pub const DEVICE_SECRET: [u8; 32] = [
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x02,
];

/// This device's own node address (derived from DEVICE_SECRET).
/// node_addr of secp256k1 generator * 2
pub const MY_NODE_ADDR: [u8; 16] = [
    0x01, 0x35, 0xda, 0x2f, 0x8a, 0xcf, 0x7b, 0x9e,
    0x30, 0x90, 0x93, 0x94, 0x32, 0xe4, 0x76, 0x84,
];

/// Peer (STM32) public key — compressed secp256k1 point (33 bytes).
/// DEFAULT_SECRET = ...0001, pubkey = secp256k1 generator * 1
pub const PEER_PUB: [u8; 33] = [
    0x02, 0x79, 0xbe, 0x66, 0x7e, 0xf9, 0xdc, 0xbb,
    0xac, 0x55, 0xa0, 0x62, 0x95, 0xce, 0x87, 0x0b,
    0x07, 0x02, 0x9b, 0xfc, 0xdb, 0x2d, 0xce, 0x28,
    0xd9, 0x59, 0xf2, 0x81, 0x5b, 0x16, 0xf8, 0x17,
    0x98,
];

/// Peer (STM32) node address (16 bytes).
/// node_addr of secp256k1 generator * 1
pub const PEER_NODE_ADDR: [u8; 16] = [
    0x13, 0x2f, 0x39, 0xa9, 0x8c, 0x31, 0xba, 0xad,
    0xdb, 0xa6, 0x52, 0x5f, 0x5d, 0x43, 0xf2, 0x95,
];

/// Device alias / friendly name.
pub const DEVICE_ALIAS: &str = "esp32-leaf";
