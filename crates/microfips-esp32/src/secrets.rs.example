// ESP32 device credentials — COPY to secrets.rs and fill in values.
// secrets.rs is gitignored and MUST NOT be committed.

/// WiFi SSID to connect to. Set to "" to skip WiFi and use serial only.
pub const WIFI_SSID: &str = "";

/// WiFi password (WPA2).
pub const WIFI_PASS: &str = "";

/// FIPS VPS hostname or IP address (e.g. "orangeclaw.dns4sats.xyz" or "1.2.3.4").
pub const FIPS_HOST: &str = "orangeclaw.dns4sats.xyz";

/// FIPS VPS UDP port.
pub const FIPS_PORT: u16 = 2121;

/// Device identity secret key (32 bytes).
/// WARNING: Replace with your own randomly generated key! Do NOT use this placeholder.
pub const DEVICE_SECRET: [u8; 32] = [
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
];

/// Peer (target) node address for FSP sessions (16 bytes).
/// This is the STM32 node address for MCU-to-MCU, or another leaf's address.
pub const PEER_NODE_ADDR: [u8; 16] = [
    0x24, 0x49, 0x21, 0xe6, 0x60, 0x6a, 0xc5, 0x8f,
    0x4b, 0x14, 0x53, 0x13, 0x36, 0x3f, 0xbb, 0x1c,
];

/// Device alias / friendly name (for future use in FIPS directory).
pub const DEVICE_ALIAS: &str = "esp32-leaf";
