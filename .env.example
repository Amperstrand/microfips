# Environment variables for VPS access and SSH
# Copy this file to .env and fill in the values
# NEVER commit .env to the repository

VPS_HOST=orangeclaw.dns4sats.xyz
VPS_USER=routstr
VPS_PASS=

# ESP32 WiFi credentials are configured in:
#   crates/microfips-esp32/src/secrets.rs (gitignored)
# Copy secrets.rs.example to secrets.rs and fill in WIFI_SSID/WIFI_PASS.
# When WIFI_SSID is empty, ESP32 falls back to UART serial transport.

